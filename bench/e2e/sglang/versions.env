# Pins for the SGLang HiCache spike (CI tripwire leg + the NOT-RUN e2e rig).
# Interface assumptions were code-read against the sglang v0.5.15.post1 tag
# (hicache_storage.py, backend_factory.py, cache_controller.py,
# memory_pool_host.py, mooncake_store.py) on 2026-07-20; PyPI checked the
# same day. Re-verify before the first real run (docs/design/
# sglang-hicache-v1.1.md names the revisit trigger).
SGLANG_VERSION=0.5.15.post1
MODEL=meta-llama/Llama-3.1-8B-Instruct
TORCH_INDEX=https://download.pytorch.org/whl/cpu
# Go toolchain for the on-pod daemon build. The repo is PRIVATE and no
# release tag ships a fetchable artifact, so runpod_up.sh builds
# ./cmd/kvblockd from the checked-out tree instead of curling a release —
# which also guarantees the daemon matches the backend under test.
GO_VERSION=1.26.5
